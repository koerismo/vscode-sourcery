{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Valve KeyValues",
	"scopeName": "text.sourcery.keyvalues",
	"patterns": [
		{ "include": "#comment" },
		{ "include": "#comment-block" },
		{ "include": "#command" },
		{ "include": "#number" },
		{ "include": "#boolean" },
		{ "include": "#query" },
		{ "include": "#string-quoted" },
		{ "include": "#string-unquoted" }
	],
	"repository": {
		"comment": {
			"name": "comment.line",
			"match": "//.*"
		},
		"comment-block": {
			"name": "comment.block",
			"begin": "/\\*",
			"end": "\\*/"
		},
		"command": {
			"name": "meta.preprocessor",
			"match": "^\\#\\w+\\b"
		},
		"number": {
			"name": "constant.numeric",
			"match": "^-?(\\d*\\.)?\\d+(e[-+]\\d+)?$"
		},
		"boolean": {
			"name": "constant.language",
			"match": "\\b(true|false)\\b"
		},
		"query": {
			"name": "keyword.control",
			"match": "\\[\\$[\\x21-\\x7A\\x7C][^\\s{}]*"
		},
		"string-quoted": {
			"name": "string.quoted",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{ "include": "#string-vector" }
			]
		},
		"string-unquoted": {
			"name": "string.unquoted",
			"match": "[\\x21-\\x7A\\x7C][^\\s{}]*"
		},
		"string-vector": {
			"begin": "[\\[\\(\\{]",
			"end": "[\\]\\)\\}]",
			"patterns": [{ "include": "#number" }],
			"captures": { "1": { "name": "storage.type" } }
		}
	}
}