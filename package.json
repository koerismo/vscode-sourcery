{
	"name": "sourcery",
	"publisher": "koerismo",
	"displayName": "Sourcery",
	"description": "Provides Source Engine filesystem support.",
	"version": "0.0.7",
	"license": "GPL-3.0-only",
	"icon": "images/icon.png",
	"engines": {
		"vscode": "^1.97.0"
	},
	"keywords": [
		"Source",
		"Source Engine",
		"Sourcery",
		"VMT",
		"VTF",
		"VPK",
		"MDL",
		"VBSP"
	],
	"categories": [
		"Visualization",
		"Other"
	],
	"activationEvents": [
		"workspaceContains:gameinfo.txt"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"languages": [
			{
				"id": "sourcery.keyvalues",
				"aliases": [
					"KeyValues",
					"kv"
				],
				"extensions": [
					".kv",
					".vdf",
					".vmf",
					"vmx"
				],
				"filenames": [
					"gameinfo.txt",
					"config.cfg",
					"panorama.cfg"
				],
				"configuration": "./langs/kv-language-configuration.json"
			},
			{
				"id": "sourcery.vmt",
				"aliases": [
					"Valve Material",
					"Source Material",
					"vmt"
				],
				"extensions": [
					".vmt"
				],
				"configuration": "./langs/kv-language-configuration.json"
			},
			{
				"id": "sourcery.qc",
				"aliases": [
					"Valve QC",
					"qc"
				],
				"extensions": [
					".qc",
					".qci"
				],
				"configuration": "./langs/kv-language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "sourcery.keyvalues",
				"scopeName": "text.sourcery.keyvalues",
				"path": "./langs/syntaxes/kv.tmLanguage.json"
			},
			{
				"language": "sourcery.vmt",
				"scopeName": "text.sourcery.keyvalues",
				"path": "./langs/syntaxes/kv.tmLanguage.json"
			},
			{
				"language": "sourcery.qc",
				"scopeName": "text.sourcery.qc",
				"path": "./langs/syntaxes/qc.tmLanguage.json"
			}
		],
		"commands": [
			{
				"command": "sourcery.game.revealFile",
				"icon": "$(file-symlink-file)",
				"title": "Reveal Original File"
			},
			{
				"command": "sourcery.game.revealRoot",
				"title": "Reveal Folder",
				"category": "Game"
			},
			{
				"command": "sourcery.game.copy",
				"title": "Copy To Mod",
				"category": "Game",
				"icon": "$(file-copy-file)"
			},
			{
				"command": "sourcery.vpk.open",
				"title": "Add Vpk to Workspace"
			},
			{
				"command": "sourcery.vmt.preview",
				"enablement": "false",
				"icon": "$(symbol-color)",
				"category": "Material",
				"title": "Open Material Preview"
			},
			{
				"command": "sourcery.vmt.browse",
				"category": "Material",
				"title": "Open Material Browser"
			},
			{
				"command": "sourcery.mdl.compile",
				"title": "Compile",
				"category": "Model",
				"icon": "$(server-process)"
			},
			{
				"command": "sourcery.detail.new",
				"title": "New",
				"category": "Detail"
			},
			{
				"command": "sourcery.vtf.retarget",
				"title": "Change Version",
				"category": "Texture"
			}
		],
		"menus": {
			"explorer/context": [
				{
					"command": "sourcery.vpk.open",
					"when": "resourceExtname == .vpk"
				},
				{
					"command": "sourcery.mdl.compile",
					"when": "resourceExtname == .qc"
				},
				{
					"command": "sourcery.vtf.retarget",
					"when": "resourceExtname == .vtf"
				}
			],
			"editor/title": [
				{
					"command": "sourcery.game.revealFile",
					"when": "resourceScheme == mod",
					"group": "navigation"
				},
				{
					"command": "sourcery.mdl.compile",
					"when": "resourceExtname == .qc",
					"group": "navigation"
				}
			]
		},
		"customEditors": [
			{
				"viewType": "sourcery.vtf",
				"displayName": "Valve Texture",
				"selector": [
					{
						"filenamePattern": "**/*.vtf"
					}
				]
			},
			{
				"viewType": "sourcery.mdl",
				"displayName": "Valve Model",
				"priority": "default",
				"selector": [
					{
						"filenamePattern": "**/*.mdl"
					}
				]
			},
			{
				"viewType": "sourcery.detail",
				"displayName": "Valve Detail",
				"priority": "default",
				"selector": [
					{
						"filenamePattern": "**/*.vbsp"
					}
				]
			}
		],
		"taskDefinitions": [
			{
				"type": "studiomdl",
				"required": [],
				"properties": {}
			}
		],
		"configuration": {
			"title": "Sourcery",
			"properties": {
				"sourcery.game.autoMount": {
					"description": "Automatically mount gameinfo.txt on workspace load?",
					"type": "boolean",
					"default": true
				},
				"sourcery.game.autoMountOnFile": {
					"description": "(TODO) Automatically mount gameinfo.txt when a file is opened which exists in a game structure?",
					"type": "boolean",
					"default": true
				},
				"sourcery.game.modPath": {
					"description": "If specified, Sourcery will mount this path as the mod root instead of the workspace root.",
					"type": "string",
					"default": "",
					"examples": [
						"~/.steam/steamapps/sourcemods/My Mod/",
						"../../"
					]
				},
				"sourcery.game.binPath": {
					"description": "The path to a game's bin folder containing studiomdl. If left blank, it will be determined automatically.",
					"type": "string",
					"default": "",
					"examples": [
						"~/.steam/steamapps/common/Portal 2/bin/"
					]
				},
				"sourcery.vmt.convertOnPaste": {
					"description": "Automatically convert textures when pasted into Vmts? If multiple textures are pasted at the same time, they are contextually merged.",
					"type": "boolean",
					"default": true
				},
				"sourcery.vmt.convertOnPasteOverwrite": {
					"description": "Allow Convert-On-Paste to overwrite existing textures?",
					"type": "boolean",
					"default": true
				},
				"sourcery.vmt.convertOnPasteResize": {
					"description": "Resize generated textures if they exceed this size.",
					"type": "integer",
					"default": 2048,
					"enum": [
						0,
						32,
						64,
						128,
						256,
						512,
						1024,
						2048,
						4096
					],
					"enumItemLabels": [
						"None",
						"32x",
						"64x",
						"128x",
						"256x",
						"512x",
						"1024x",
						"2048x",
						"4096x"
					]
				},
				"sourcery.vmt.convertOnPasteResizeTooltexture": {
					"description": "Resize textures generated for %tooltexture if they exceed this size.",
					"type": "integer",
					"default": 256,
					"enum": [
						0,
						32,
						64,
						128,
						256,
						512,
						1024
					],
					"enumItemLabels": [
						"None",
						"32x",
						"64x",
						"128x",
						"256x",
						"512x",
						"1024x"
					]
				},
				"sourcery.vmt.warnModelPath": {
					"description": "Enable warnings for paths that begin with props_xyz instead of models/props_xyz?",
					"type": "boolean",
					"default": true
				},
				"sourcery.vmt.notFound": {
					"description": "Enable warnings for missing textures?",
					"type": "boolean",
					"default": true
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "pnpm run package",
		"make-addon": "pnpm vsce package --no-dependencies",
		"build": "node build.mts",
		"watch": "node build.mts --watch",
		"lint": "eslint src --ext ts"
	},
	"devDependencies": {
		"@types/json-schema": "^7.0.15",
		"@types/mocha": "^10.0.10",
		"@types/node": "~25.5.0",
		"@types/three": "^0.183.1",
		"@types/vscode": "^1.110.0",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@typescript-eslint/parser": "^8.58.0",
		"@vscode/codicons": "^0.0.45",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/webview-ui-toolkit": "^1.4.0",
		"@vscode/windows-registry": "^1.2.0",
		"@webgpu/types": "^0.1.69",
		"crc-32": "^1.2.2",
		"css-loader": "^7.1.4",
		"esbuild": "^0.28.0",
		"eslint": "^10.1.0",
		"fast-png": "^8.0.0",
		"fast-vdf": "^3.0.0",
		"gl-matrix": "^3.4.4",
		"image-decode": "^1.2.2",
		"mocha": "^11.7.5",
		"node-loader": "^2.1.0",
		"raw-loader": "^4.0.2",
		"sfs-js": "link:../sfs-js",
		"source-engine-model-loader": "github:gkjohnson/source-engine-model-loader",
		"struxt": "^3.6.1",
		"stupid-buffer": "^1.0.3",
		"style-loader": "^4.0.0",
		"three": "^0.183.2",
		"ts-loader": "^9.5.4",
		"typescript": "^5.9.3",
		"vtf-js": "link:../vtf-js",
		"webpack": "^5.105.4",
		"webpack-cli": "^7.0.2"
	},
	"dependencies": {
		"@types/vscode-webview": "^1.57.5"
	}
}
